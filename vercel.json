{
  "installCommand": "npm install && npm --prefix frontend install && npm --prefix backend install",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "/api/uploads/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
